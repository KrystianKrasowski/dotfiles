#!/usr/bin/env bash

tmp_file=/tmp/weather

temp="---"
int_temp="---"

# purple
color_freezing="ab9df2"

# cyan
color_cold="78dce8"
 
# white
color_average="fcfcfa"
 
#green
color_warm="a9dc76"
 
# yellow
color_hot="ffd866"

# orange
color_burning="fc9867"
 
color="$color_average"

if [ -f "$tmp_file" ]; then
    temp=$(cat "$tmp_file" | cut -d ',' -f 5)
fi

int_temp=$(echo "$temp" | cut -d '.' -f 1)

if [ "$int_temp" -le -15 ]; then
    color="$color_freezing"
elif [ "$int_temp" -le 8 ]; then
    color="$color_cold"
elif [ "$int_temp" -le 16 ]; then
    color="$color_average"
elif [ "$int_temp" -le 25 ]; then
    color="$color_warm"
elif [ "$int_temp" -le 32 ]; then
    color="$color_hot"
elif [ "$int_temp" -le 40 ]; then
    color="$color_burning"
fi

name="temperature"
full_text=" <small>$temp °C</small>"
min_width=17
align="center"
separator="true"
separator_block_width=25
markup="pango"
urgent="false"

echo "$full_text|$min_width|$align|$separator|$separator_block_width|$markup|$name|$color|$urgent"

